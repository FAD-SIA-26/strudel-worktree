# OpenAI API Configuration
# Copy this file to .env and fill in your actual values
# .env is gitignored and will never be committed

# Required: Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-key-here...

# Optional: Override the default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Use a different OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Override the orchestrator database location
# ORC_DB_PATH=/path/to/custom/orc.db

# Optional: Override API server port (default: 4000)
# ORC_PORT=4000

# Optional: Override dashboard port (default: 3000)
# ORC_DASHBOARD_PORT=3000

# Optional: Override repository root (usually auto-detected)
# ORC_REPO_ROOT=/path/to/repo
